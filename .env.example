# =====================================================================
# Portal Kelurahan Wergu Wetan - Environment Variables Template
# ---------------------------------------------------------------------
# Salin file ini menjadi `.env` lalu isi nilai sesuai environment Anda.
# JANGAN commit file `.env` ke git (sudah di-ignore lewat .gitignore).
# =====================================================================

# ----- Database (PostgreSQL) -----
# Connection string untuk Prisma ORM. Bisa menggunakan:
#  - Supabase (hosted PostgreSQL) — gunakan DATABASE_URL dengan ?pgbouncer=true
#  - Self-hosted PostgreSQL (local atau VPS) — standard connection string
#  - Neon / Railway / Render PostgreSQL — format standard postgresql://
#
# Format Supabase (recommended production):
#   DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
#   DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.supabase.com:5432/postgres"
#
# Format PostgreSQL lokal / self-hosted:
#   DATABASE_URL="postgresql://postgres:postgres@localhost:5432/wergu_wetan?schema=public"
#   DIRECT_URL="postgresql://postgres:postgres@localhost:5432/wergu_wetan?schema=public"
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"

# ----- Authentication (JWT) -----
# Secret untuk sign/verify JWT admin (HS256, exp 24 jam).
# Wajib string acak panjang (minimal 32 karakter). Generate contoh:
#   PowerShell : [Convert]::ToBase64String((1..48 | % { Get-Random -Maximum 256 }))
#   OpenSSL    : openssl rand -base64 48
JWT_SECRET="ganti-dengan-secret-acak-yang-panjang-minimal-32-karakter"

# ----- Public Site URL -----
# Base URL portal publik. Dipakai untuk sitemap.xml, metadata SEO, dsb.
# Development: https://localhost:3000
# Production : https://wergu-wetan.id
NEXT_PUBLIC_SITE_URL="https://localhost:3000"
