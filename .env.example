# ╔══════════════════════════════════════════════════════════════════╗
# ║  Portal Web Terpadu Kelurahan Wergu Wetan                      ║
# ║  Environment Variables Template                                 ║
# ║                                                                 ║
# ║  CARA PAKAI:                                                    ║
# ║  1. Salin file ini: cp .env.example .env                       ║
# ║  2. Isi semua nilai yang kosong (lihat komentar tiap variabel)  ║
# ║  3. JANGAN PERNAH commit file .env ke Git!                     ║
# ╚══════════════════════════════════════════════════════════════════╝

# ─────────────────────────────────────────────────────────────────
# DATABASE (Supabase PostgreSQL)
# Ambil dari: Supabase Dashboard → Project Settings → Database
# ─────────────────────────────────────────────────────────────────

# Pooled connection — untuk runtime queries (Next.js app server)
# Port: 6543 | Gunakan ?pgbouncer=true di akhir URL
DATABASE_URL=""
# Contoh: DATABASE_URL="postgresql://postgres.xxx:PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection — untuk migrations (prisma migrate dev)
# Port: 5432 | JANGAN pakai pgbouncer untuk direct
DIRECT_URL=""
# Contoh: DIRECT_URL="postgresql://postgres.xxx:PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# ─────────────────────────────────────────────────────────────────
# AUTHENTICATION (JWT)
# Generate dengan: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Panjang minimum: 64 karakter
# ─────────────────────────────────────────────────────────────────

JWT_SECRET=""
# Contoh: JWT_SECRET="a3f8b2c1d9e4f7a0b5c8d3e6f1a4b7c2d5e8f3a6b9c0d1e2f5a8b1c4d7e0f3"

# ─────────────────────────────────────────────────────────────────
# SITE URL (Public)
# URL publik aplikasi — digunakan untuk Server Actions dan metadata
# Development: https://localhost:3000 (HTTPS karena experimental-https)
# Production:  https://wergu-wetan.id (tanpa trailing slash)
# ─────────────────────────────────────────────────────────────────

NEXT_PUBLIC_SITE_URL=""
# Contoh (dev):  NEXT_PUBLIC_SITE_URL="https://localhost:3000"
# Contoh (prod): NEXT_PUBLIC_SITE_URL="https://wergu-wetan.id"

# ─────────────────────────────────────────────────────────────────
# CATATAN UNTUK VERCEL DEPLOYMENT
# ─────────────────────────────────────────────────────────────────
# Tambahkan semua variabel di atas ke:
# Vercel Dashboard → Project → Settings → Environment Variables
#
# Pilih environment:
#   Production  → nilai produksi (URL Supabase production)
#   Preview     → boleh sama dengan production
#   Development → nilai lokal (opsional, lebih mudah pakai .env lokal)
