# =====================================================================
# Portal Kelurahan Wergu Wetan — Environment Template
# ---------------------------------------------------------------------
# File ini adalah template aman untuk dikommit ke git.
# Salin menjadi `.env` dan isi dengan nilai asli (jangan commit .env!).
# =====================================================================

# ----- Database (PostgreSQL) -----
# Gunakan Supabase pooled URL untuk production, atau PostgreSQL lokal.
# Contoh:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/wergu_wetan?schema=public"
# DIRECT_URL="postgresql://postgres:postgres@localhost:5432/wergu_wetan?schema=public"
DATABASE_URL=""
DIRECT_URL=""

# ----- Authentication (JWT) -----
# Generate secret kuat (min 64 chars). Di produksi, simpan di secrets manager.
JWT_SECRET=""

# ----- Public Site URL -----
# URL publik aplikasi (tanpa trailing slash).
NEXT_PUBLIC_SITE_URL=""
